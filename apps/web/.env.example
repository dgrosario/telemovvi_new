# =============================================================================
# CONFIGURAÇÃO PARA DOCKER COMPOSE (Desenvolvimento Local)
# =============================================================================
# Use os nomes dos serviços do docker-compose.yml como hostname
# O docker-compose.yml já sobrescreve algumas dessas variáveis

# Database
DATABASE_URL=postgresql://omnichannel:omnichannel@postgres:5432/omnichannel

# RabbitMQ
RABBITMQ_URL=amqp://omnichannel:omnichannel@rabbitmq:5672

# Application
APP_DOMAIN=http://localhost:3000
INTERNAL_API_KEY=dev-internal-api-key

# =============================================================================
# CONFIGURAÇÃO PARA DESENVOLVIMENTO SEM DOCKER (Local)
# =============================================================================
# Se rodar apps localmente (pnpm dev), use localhost com portas mapeadas:
# DATABASE_URL=postgresql://omnichannel:omnichannel@localhost:5434/omnichannel
# RABBITMQ_URL=amqp://omnichannel:omnichannel@localhost:5672

# =============================================================================
# OPCIONAIS
# =============================================================================
# Omni Gateway (opcional - defaults to http://localhost:3001)
# OMNI_GATEWAY_URL=http://omni-gateway:3001
# OMNI_GATEWAY_API_KEY=your-gateway-api-key

# Server (optional)
# PORT=3000
# ALLOWED_ORIGINS=https://app.yourdomain.com,https://admin.yourdomain.com

# Cron Jobs (required for campaigns)
# CRON_SECRET=your-secure-cron-secret
# EVOLUTION_ORPHAN_CLEANUP_MAX_PER_RUN=20

# =============================================================================
# PRODUCAO - Server Actions
# =============================================================================
# Chave para manter IDs de server actions consistentes entre deploys.
# OBRIGATORIO em producao para evitar erros "Server Action Not Found" apos deploys.
# Gerar com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=
