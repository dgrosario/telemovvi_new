# =============================================================================
# GATEWAY CONFIGURATION (Message Broker)
# =============================================================================

# Server
PORT=3001
LOG_LEVEL=info

# Redis (for meta settings storage)
REDIS_URL=redis://localhost:6379

# Main SaasCRM Database (for channels/messages access)
MAIN_DATABASE_URL=postgresql://omnichannel:omnichannel@localhost:5434/omnichannel

# RabbitMQ
RABBITMQ_URL=amqp://omnichannel:omnichannel@localhost:5672
EXCHANGE_NAME=evolution_exchange
OUTBOUND_QUEUE=outbound-messages
OUTBOUND_DLQ=outbound-messages.dlq

# Evolution API (WhatsApp)
EVOLUTION_URL=http://localhost:8080
EVOLUTION_API_KEY=your-evolution-api-key

# Meta API (Instagram, Messenger)
META_WEBHOOK_VERIFY_TOKEN=your-webhook-verify-token
META_APP_SECRET=your-meta-app-secret
META_APP_CLIENT_ID=your-meta-app-client-id

# Gateway Public URL (for webhook callbacks - required for WhatsApp Cloud API)
# In production: https://gateway.telemovvi.com.br
# In development: your ngrok URL
GATEWAY_PUBLIC_URL=https://gateway.telemovvi.com.br

# Circuit Breaker (optional)
CIRCUIT_BREAKER_TIMEOUT=15000
CIRCUIT_BREAKER_ERROR_THRESHOLD=50
CIRCUIT_BREAKER_RESET_TIMEOUT=30000
CIRCUIT_BREAKER_VOLUME_THRESHOLD=5

# Media Storage
# IMPORTANT: For Evolution API, keep auto-delete DISABLED (false or 0)
# Evolution media URLs expire in 5-10 minutes, so local storage is permanent
MEDIA_AUTO_DELETE_ENABLED=false
MEDIA_FILE_TTL_HOURS=0
MEDIA_STORAGE_PATH=/data/media
MEDIA_MAX_RETRIES=3
MEDIA_RETRY_DELAY_MS=2000
