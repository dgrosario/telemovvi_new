{
  "name": "@omnichannel/core",
  "type": "module",
  "scripts": {
    "db:migrate": "pnpm exec drizzle-kit migrate",
    "db:generate": "pnpm exec drizzle-kit generate",
    "db:drop": "pnpm exec drizzle-kit drop",
    "db:seed": "pnpm tsx ./src/infra/database/seed.ts",
    "db:seed:dev": "pnpm tsx ./src/infra/database/seed-dev.ts",
    "test": "vitest",
    "test:e2e": "vitest --config vitest.e2e.config.ts",
    "test:e2e:run": "vitest run --config vitest.e2e.config.ts"
  },
  "exports": {
    "./*": "./src/*"
  },
  "dependencies": {
    "@opendocsg/pdf2md": "^0.2.1",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-trace-otlp-proto": "0.201.1",
    "amqplib": "^0.10.9",
    "axios": "^1.10.0",
    "bcrypt": "^6.0.0",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.0",
    "form-data": "^4.0.4",
    "ioredis": "^5.8.2",
    "jsonwebtoken": "^9.0.2",
    "postgres": "^3.4.7",
    "vitest": "^3.2.4",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@omnichannel/typescript-config": "workspace:*",
    "@types/amqplib": "^0.10.7",
    "@types/bcrypt": "^6.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.3.0",
    "drizzle-kit": "^0.31.8",
    "jest": "^30.1.3",
    "socket.io": "^4.8.1",
    "vite": "^7.1.2",
    "vite-tsconfig-paths": "^5.1.4"
  }
}
