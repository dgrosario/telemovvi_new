# Evolution API Test Instance Configuration
# This is the "test client" - a separate WhatsApp number used to send/receive test messages
TEST_EVOLUTION_URL=http://localhost:8080
TEST_EVOLUTION_API_KEY=omnichannel-local-key
TEST_EVOLUTION_INSTANCE_NAME=test-client

# Platform Channel Configuration (the channel being tested)
# This is the production/staging channel that will receive messages from the test client
TEST_PLATFORM_INSTANCE_NAME=your-production-instance
TEST_PLATFORM_CHANNEL_ID=uuid-of-the-channel
TEST_PLATFORM_WORKSPACE_ID=uuid-of-the-workspace

# Phone Numbers
# TEST_CLIENT_PHONE_NUMBER: The WhatsApp number registered as test-client
# TEST_PLATFORM_PHONE_NUMBER: The WhatsApp number of the platform channel
TEST_CLIENT_PHONE_NUMBER=5511999999999
TEST_PLATFORM_PHONE_NUMBER=5511888888888

# Database Connection (same as production/staging)
DATABASE_URL=postgresql://omnichannel:omnichannel@localhost:5432/omnichannel

# RabbitMQ Connection
RABBITMQ_URL=amqp://omnichannel:omnichannel@localhost:5672

# Outbound Queue Name
OUTBOUND_QUEUE=omnichannel-infocell

# Timeouts (in milliseconds)
TEST_MESSAGE_DELIVERY_TIMEOUT=30000
TEST_RESPONSE_TIMEOUT=60000
TEST_POLL_INTERVAL=1000
