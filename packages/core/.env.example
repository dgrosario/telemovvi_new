# Database
DATABASE_URL=postgresql://user:password@localhost:5432/omnichannel

# Seed User (development/staging)
USER_NAME_STAGING=Admin
USER_EMAIL_STAGING=admin@omnichannel.local
USER_PASSWORD_STAGING=admin123

# RabbitMQ (optional - has defaults)
# RABBITMQ_URL=amqp://user:password@localhost:5672
# EXCHANGE_NAME=meta_exchange
# OUTBOUND_QUEUE=outbound-messages
# INTERNAL_QUEUE=internal-messages

# Evolution RabbitMQ (optional)
# EVOLUTION_RABBITMQ_URL=amqp://user:password@localhost:5672
# EVOLUTION_RABBITMQ_EXCHANGE=evolution_exchange

# Meta (required for WhatsApp/Instagram)
# META_APP_SECRET=your-meta-app-secret
