# =============================================================================
# Omnichannel - Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values
# Usage: docker compose --env-file .env up -d
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL Database
# -----------------------------------------------------------------------------
POSTGRES_DB=omnichannel
POSTGRES_USER=omnichannel
POSTGRES_PASSWORD=your-secure-postgres-password-here
POSTGRES_PORT=5432
POSTGRES_CONTAINER_NAME=omnichannel-postgres-prod

# -----------------------------------------------------------------------------
# RabbitMQ Message Broker
# -----------------------------------------------------------------------------
RABBITMQ_USER=omnichannel
RABBITMQ_PASSWORD=your-secure-rabbitmq-password-here
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_CONTAINER_NAME=omnichannel-rabbitmq-prod

# -----------------------------------------------------------------------------
# Redis Cache
# -----------------------------------------------------------------------------
REDIS_PORT=6379
REDIS_CONTAINER_NAME=omnichannel-redis-prod

# -----------------------------------------------------------------------------
# Evolution API (WhatsApp Integration)
# -----------------------------------------------------------------------------
# Version of Evolution API image
EVOLUTION_VERSION=v2.3.6

# Public URL where Evolution API will be accessible (for QR code callbacks)
EVOLUTION_SERVER_URL=https://evolution.yourdomain.com

# API Key for Evolution API authentication
EVOLUTION_API_KEY=your-secure-evolution-api-key-here

# Port to expose Evolution API
EVOLUTION_PORT=8080

# Container name
EVOLUTION_CONTAINER_NAME=omnichannel-evolution-prod

# Optional settings
EVOLUTION_EXPOSE_INSTANCES=true
EVOLUTION_REDIS_PREFIX=evolution
EVOLUTION_RABBITMQ_EXCHANGE=evolution_exchange
EVOLUTION_QRCODE_LIMIT=6
EVOLUTION_LOG_LEVEL=ERROR,WARN

# -----------------------------------------------------------------------------
# Web Application
# -----------------------------------------------------------------------------
WEB_PORT=3000
WEB_CONTAINER_NAME=omnichannel-web-prod
WEB_IMAGE_NAME=omnichannel-web:latest

# Public URL of the web application
APP_DOMAIN=https://app.yourdomain.com

# -----------------------------------------------------------------------------
# Meta/WhatsApp Business API (opcional - fallback se nao configurado por canal)
# -----------------------------------------------------------------------------
# META_APP_SECRET=
# META_APP_CLIENT_ID=
# META_WEBHOOK_VERIFY_TOKEN=

# -----------------------------------------------------------------------------
# Omni-Gateway Service
# -----------------------------------------------------------------------------
GATEWAY_PORT=3001
GATEWAY_CONTAINER_NAME=omnichannel-gateway-prod
GATEWAY_IMAGE_NAME=omnichannel-gateway:latest
LOG_LEVEL=info

# URL publica do gateway (usado para exibir URL do webhook na UI)
NEXT_PUBLIC_GATEWAY_URL=https://gateway.yourdomain.com

# Message Broker Queues
EXCHANGE_NAME=meta_exchange
OUTBOUND_QUEUE=outbound-messages
OUTBOUND_DLQ=outbound-messages.dlq
INTERNAL_QUEUE=internal-messages
INTERNAL_DLQ=internal-messages.dlq
