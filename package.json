{
  "name": "omnichannel",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter @omnichannel/web",
    "dev:gateway": "turbo run dev --filter @saascrm/gateway",
    "start": "turbo run start --filter @omnichannel/web",
    "start:web": "turbo run start --filter @omnichannel/web",
    "start:gateway": "turbo run start --filter @saascrm/gateway",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "db:migrate": "docker compose exec web pnpm --filter @omnichannel/core run db:migrate",
    "db:generate": "docker compose exec web pnpm --filter @omnichannel/core run db:generate",
    "db:drop": "docker compose exec web pnpm --filter @omnichannel/core run db:drop",
    "db:seed": "docker compose exec web pnpm --filter @omnichannel/core run db:seed",
    "db:seed:dev": "docker compose exec web pnpm --filter @omnichannel/core run db:seed:dev",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "docker:logs:web": "docker compose logs -f web",
    "docker:logs:gateway": "docker compose logs -f omni-gateway"
  },
  "devDependencies": {
    "prettier": "^3.6.2",
    "tsx": "^4.20.6",
    "turbo": "^2.6.1",
    "typescript": "5.8.3",
    "vitest": "^4.0.8"
  },
  "packageManager": "pnpm@10.26.2",
  "engines": {
    "node": ">=22.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "bcrypt",
      "@swc/core",
      "@swc/cli",
      "@nestjs/core",
      "@sentry/cli",
      "canvas",
      "protobufjs"
    ]
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "dependencies": {
    "immer": "^10.2.0",
    "react-toastify": "^11.0.5",
    "reactflow": "^11.11.4",
    "remark-breaks": "^4.0.0",
    "use-mask-input": "^3.5.2",
    "zod": "^3.25.76",
    "zustand": "^5.0.8"
  }
}
